{
  "name": "freellmapi-cf",
  "version": "0.1.0",
  "description": "OpenAI-compatible LLM proxy on Cloudflare Workers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "db:init": "wrangler d1 execute freellmapi --file=./schema.sql",
    "db:init:prod": "wrangler d1 execute freellmapi-prod --file=./schema.sql --env production",
    "secret:set": "wrangler secret put",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  }
}
